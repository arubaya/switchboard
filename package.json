{
  "name": "switchboard",
  "version": "1.0.0",
  "description": "Lightweight reverse proxy with a web dashboard",
  "type": "module",
  "main": "dist/server.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arubaya/switchboard.git"
  },
  "bugs": {
    "url": "https://github.com/arubaya/switchboard/issues"
  },
  "homepage": "https://github.com/arubaya/switchboard#readme",
  "keywords": [
    "reverse-proxy",
    "fastify",
    "ssl",
    "letsencrypt",
    "dashboard"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "npm run build && node --test dist/shared/version.test.js",
    "css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/output.css --watch",
    "css:build": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/output.css --minify"
  },
  "author": "arubaya",
  "dependencies": {
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/http-proxy": "^11.6.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/view": "^12.0.0",
    "acme-client": "^5.4.0",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "eta": "^4.6.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
